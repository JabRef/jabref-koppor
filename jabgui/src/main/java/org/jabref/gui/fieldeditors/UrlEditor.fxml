<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.HBox?>
<?import org.jabref.gui.fieldeditors.EditorTextField?>
<?import org.jabref.gui.icon.JabRefIconView?>
<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://jfxcore.org/fxml/2.0"
      fx:subclass="org.jabref.gui.fieldeditors.UrlEditor">
    <EditorTextField fx:id="textField" prefHeight="0.0" HBox.hgrow="ALWAYS"/>
    <Button disable="${viewModel.validUrlIsNotPresent}" onAction="openExternalLink"
            styleClass="icon-button">
        <graphic>
            <JabRefIconView glyph="OPEN_LINK"/>
        </graphic>
        <tooltip>
            <Tooltip text="%Open"/>
        </tooltip>
    </Button>
</HBox>
